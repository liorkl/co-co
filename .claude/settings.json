{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(gh *)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*credentials*)",
      "Read(*secret*)",
      "Read(*.key)",
      "Read(*.pem)"
    ]
  }
}
