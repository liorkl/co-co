{
  "permissions": {
    "allow": [
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git log *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(gh pr *)",
      "Bash(gh auth status)",
      "Edit(**)",
      "Write(**)"
    ],
    "deny": [
      "Read(.env*)",
      "Read(*credentials*)",
      "Read(*secret*)",
      "Read(*.key)",
      "Read(*.pem)"
    ]
  }
}
